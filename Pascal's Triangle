class Solution {
public:
    vector<vector<int>> generate(int numRows) {
        vector<vector<int>> b(numRows);
    for (int i = 0; i < numRows; i++) {
        b[i].resize(i + 1, 1);  // fill with 1s by default
        for (int j = 1; j < i; j++) {
            b[i][j] = b[i-1][j-1] + b[i-1][j];  // sum from row above
        }
    }
    return b;
}
    
};
