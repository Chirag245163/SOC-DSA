class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int min_index=0;
        int max_profit=0;
        for(int i=1;i<prices.size();i++){
            if(prices[min_index]>prices[i]){
                min_index=i;
            }
            else{
                max_profit=max(max_profit,prices[i]-prices[min_index]);
            }
        }
        return max_profit;
    }
};
